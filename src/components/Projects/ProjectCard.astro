---
import {
  Card,
  CardContent,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/starwind/card";
import { Image } from "astro:assets";
import Technos from "@/components/Technos.astro";
import type { Project } from "@/schemas/project";

interface Props {
  project: Project;
  id: string;
}
const { project, id } = Astro.props;

const href = project.hasDetailsPage ? `/projects/${id}` : (project.link ?? "");
const isExternal = !project.hasDetailsPage;
---

<!-- TODO : ajouter le hasdetailpage pour savoir sur quoi rediriger -->
<a href={href} target={isExternal ? "_blank" : undefined}>
  <Card
    class="group card-shadow hover-card border-border/75 flex h-full flex-col overflow-hidden transition-all duration-300"
  >
    <div class="relative overflow-hidden">
      {
        project.image && project.image.media.src ? (
          <Image
            src={project.image.media}
            alt={project.name}
            width={800}
            height={600}
            class="h-56 w-full object-cover object-center transition-transform duration-500 group-hover:scale-110"
          />
        ) : (
          <div class="from-primary to-accent flex h-56 w-full flex-col justify-center bg-gradient-to-br">
            <h3 class="text-primary-foreground text-center">{project.name}</h3>
          </div>
        )
      }
      <div
        class="from-card absolute inset-0 bg-gradient-to-t to-transparent opacity-0 transition-opacity group-hover:opacity-65"
      >
      </div>
      <span
        class:list={[
          "absolute top-3 right-3 rounded-full px-3 py-1 text-xs font-semibold shadow-md",
          project.status === "done"
            ? "bg-green-700 text-white"
            : "bg-amber-700 text-white",
        ]}
      >
        {project.status === "done" ? "Done" : "In progress"}
      </span>
    </div>

    <CardHeader class="pb-2">
      <CardTitle class="text-primary font-heading text-2xl tracking-tight">
        {project.name}
      </CardTitle>
    </CardHeader>

    <CardContent class="flex-grow">
      <p class="text-muted-foreground text-sm leading-relaxed">
        {project.description}
      </p>
    </CardContent>

    <CardFooter
      class="bg-muted/60 border-border/70 flex flex-col gap-4 border-t pt-4 pb-4"
    >
      <div class="w-full">
        <Technos technos={project.technos} />
      </div>
    </CardFooter>
  </Card>
</a>
