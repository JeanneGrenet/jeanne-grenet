---
import Button from "./starwind/button";

const navigation = [
  { name: "Home", href: "/" },
  { name: "Blog", href: "/blog" },
];
---

<header class="fixed inset-x-0 top-0 z-50 px-4 py-3">
  <div
    class="border-border/70 bg-card/85 mx-auto flex h-14 max-w-6xl items-center justify-between rounded-full border px-8 shadow-lg backdrop-blur-xl"
  >
    <div class="mr-4 flex items-center gap-3">
      <a href="/" class="flex items-center gap-3">
        <span class="text-primary font-heading text-lg tracking-wide">
          Jeanne Grenet
        </span>
      </a>
    </div>

    <nav class="hidden flex-1 items-center justify-center md:flex">
      <ul
        class="bg-background/85 border-border/60 flex gap-1 rounded-full border p-1"
      >
        {
          navigation.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-muted-foreground hover:text-foreground hover:bg-secondary/70 rounded-full px-4 py-1.5 text-sm font-medium transition-colors"
              >
                {item.name}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-4">
      <Button
        variant="outline"
        size="sm"
        class="border-primary/45 bg-background/80 hover:border-primary rounded-full px-4 font-semibold"
      >
        <a
          href="/resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="tracking-wide"
        >
          Resume
        </a>
      </Button>
    </div>
  </div>
</header>
