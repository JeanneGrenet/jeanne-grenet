---
import Button from "./starwind/button";
import { RxHamburgerMenu } from "react-icons/rx";
import {
  Dropdown,
  DropdownTrigger,
  DropdownContent,
  DropdownItem,
} from "./starwind/dropdown";

const navigation = [
  { name: "Home", href: "/" },
  { name: "Blog", href: "/blog" },
];
---

<header class="fixed inset-x-0 top-0 z-50 px-4 py-3">
  <div
    class="border-border/70 bg-card/85 mx-auto flex h-14 max-w-6xl items-center justify-between rounded-2xl border px-2 pl-4 shadow-lg backdrop-blur-xl"
  >
    <div class="mr-4 flex items-center gap-3">
      <a href="/" class="flex items-center gap-3">
        <span class="text-primary font-heading text-lg tracking-wide">
          Jeanne Grenet
        </span>
      </a>
    </div>

    <nav class="hidden flex-1 items-center justify-center md:flex">
      <ul class="flex gap-1 rounded-full p-1">
        {
          navigation.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-muted-foreground hover:text-foreground hover:bg-secondary/70 rounded-full px-4 py-1.5 text-sm font-medium transition-colors"
              >
                {item.name}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-2">
      <Button variant="outline" size="sm">
        <a
          href="/resume.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="tracking-wide"
        >
          Resume
        </a>
      </Button>

      <div class="md:hidden">
        <Dropdown>
          <DropdownTrigger
            class="text-muted-foreground hover:text-foreground hover:bg-secondary/70 rounded-lg p-2"
            aria-label="Menu de navigation"
          >
            <RxHamburgerMenu className="size-5" />
          </DropdownTrigger>
          <DropdownContent align="end" class="min-w-[10rem]">
            {
              navigation.map((item) => (
                <DropdownItem as="a" href={item.href}>
                  {item.name}
                </DropdownItem>
              ))
            }
          </DropdownContent>
        </Dropdown>
      </div>
    </div>
  </div>
</header>
