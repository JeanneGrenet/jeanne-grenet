---
import { LuArrowUpRight } from "react-icons/lu";
import {
  Card,
  CardContent,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/starwind/card";
import { Image } from "astro:assets";
import Button from "@/components/starwind/button";
import { getCollection } from "astro:content";

const contributions = await getCollection("opensourceContributions");
---

<section class="flex flex-col gap-4">
  <div class="mb-2 flex items-center gap-3">
    <h2 class="text-primary text-3xl font-bold">My OpenSource contributions</h2>
    <div class="bg-primary/30 h-px flex-1"></div>
  </div>

  <div class="flex w-full gap-6">
    {
      contributions.map((contribution) => (
        <Card>
          <CardHeader>
            <CardTitle class="text-primary font-semibold">
              {contribution.data.name}
            </CardTitle>
          </CardHeader>
          <CardContent class="flex flex-col gap-4">
            {contribution.data.image && (
              <Image
                src={contribution.data.image?.media}
                alt={contribution.data.image?.alt}
                width={400}
                height={300}
                class="h-56 w-full rounded-md object-cover object-center"
              />
            )}
            <p>{contribution.data.description}</p>
          </CardContent>
          {contribution.data.link && (
            <CardFooter>
              <Button variant="primary">
                <a
                  href={contribution.data.link}
                  target="_blank"
                  class="flex items-center gap-1"
                >
                  Learn more <LuArrowUpRight />
                </a>
              </Button>
            </CardFooter>
          )}
        </Card>
      ))
    }
  </div>
</section>
