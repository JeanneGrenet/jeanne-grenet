---
import SOCIALS from "./constants/SOCIALS";
const year = new Date().getFullYear();
---

<footer
  class="border-primary/10 bg-secondary/20 mt-16 w-full border-t px-4 py-6"
>
  <div
    class="container mx-auto flex flex-col gap-4 md:flex-row md:justify-between"
  >
    <p class="text-muted-foreground text-sm">
      © {year}{" "}
      <span class="text-primary font-medium">Jeanne Grenet</span>. All rights
      reserved.
    </p>

    <div class="flex gap-4">
      {
        SOCIALS.filter((social) => social.link).map((social) => (
          <a
            href={social.link}
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-primary transition-colors"
            aria-label={social.name}
          >
            <social.icon className="h-5 w-5" />
          </a>
        ))
      }
    </div>
  </div>
</footer>
