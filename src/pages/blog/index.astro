---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { LuArrowUpRight } from "react-icons/lu";
const articles = await getCollection("articles");
---

<Layout>
  <section
    class="mx-auto h-full max-w-6xl px-4 pt-28 pb-24 [column-fill:_balance] sm:px-6 md:columns-2 lg:columns-3"
  >
    {
      articles.map((article) => (
        <a
          href={
            article.data.externalUrl
              ? article.data.externalUrl
              : `/blog/${article.id}`
          }
          target={article.data.externalUrl ? "_blank" : undefined}
          rel={article.data.externalUrl ? "noopener noreferrer" : undefined}
          class="group mb-6 block break-inside-avoid rounded-2xl transition-all duration-300 hover:scale-[1.015]"
        >
          <figure class="bg-muted border-border/70 relative aspect-square w-full overflow-hidden rounded-2xl border shadow-md transition-shadow duration-300 group-hover:shadow-xl">
            {article.data.externalUrl && (
              <span class="bg-foreground/80 text-background absolute top-3 right-3 z-10 flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold shadow-md">
                External <LuArrowUpRight className="h-3 w-3" />
              </span>
            )}
            {article.data.image ? (
              <Image
                src={article.data.image.media}
                alt={article.data.image.alt}
                width={800}
                height={800}
                class="absolute inset-0 h-full w-full object-contain transition-transform duration-500 ease-out group-hover:scale-120"
                loading="lazy"
                sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
              />
            ) : (
              <div class="from-primary to-accent absolute inset-0 grid place-items-center bg-gradient-to-br p-4 transition-all duration-500 group-hover:scale-105 group-hover:rotate-2">
                <h3 class="text-primary-foreground text-center text-lg font-medium transition-transform duration-300 group-hover:scale-110">
                  {article.data.title}
                </h3>
              </div>
            )}
          </figure>

          <h3 class="group-hover:text-primary mt-3 line-clamp-2 text-lg font-semibold transition-colors duration-300">
            {article.data.title}
          </h3>
          <p class="text-muted-foreground group-hover:text-foreground/80 mt-1 line-clamp-2 text-sm leading-relaxed transition-all duration-300">
            {article.data.description}
          </p>
        </a>
      ))
    }
  </section>
</Layout>
